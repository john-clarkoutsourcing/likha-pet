rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Public read-only catalogs (seeded at deploy, never client-writable) ────
    match /traits/{traitId} {
      allow read:  if true;
      allow write: if false;
    }
    match /monsters/{monsterId} {
      allow read:  if true;
      allow write: if false;
    }
    match /stages/{stageId} {
      allow read:  if true;
      allow write: if false;
    }
    match /chapters/{chapterId} {
      allow read:  if true;
      allow write: if false;
    }
    match /bosses/{bossId} {
      allow read:  if true;
      allow write: if false;
    }

    // ── Users ──────────────────────────────────────────────────────────────────
    // Auth uses a custom JWT system (not Firebase Auth), so request.auth is null.
    // Access is open for now — lock down once Firebase custom tokens are wired up.
    match /users/{uid} {
      allow read, write: if true;

      // ── Team compositions (subcollection) ───────────────────────────────────
      match /teams/{teamId} {
        allow read, write: if true;
      }
    }

    // ── Pets ───────────────────────────────────────────────────────────────────
    match /pets/{petId} {
      allow read:   if request.auth != null;
      allow create: if request.auth.uid == request.resource.data.ownerId;
      // Clients can rename/reconfigure but never alter base stats
      allow update: if request.auth.uid == resource.data.ownerId
                    && !request.resource.data.diff(resource.data)
                        .affectedKeys()
                        .hasAny(['baseHp', 'baseAttack', 'baseDefense', 'baseSpeed']);
      allow delete: if request.auth.uid == resource.data.ownerId;
    }

    // ── Battles ────────────────────────────────────────────────────────────────
    match /battles/{battleId} {
      allow read: if request.auth != null && isParticipant(battleId);

      // Clients may only CREATE PvE audit documents (not PvP — CF creates those)
      allow create: if request.auth != null
                    && request.resource.data.mode == 'pve'
                    && request.resource.data.participants.teamA.playerId
                       == request.auth.uid;

      // Battle state is ALWAYS write-locked to clients.
      // Only Cloud Functions via Admin SDK may update battle documents.
      allow update: if false;
      allow delete: if false;
    }

    // ── Pending actions (PvP turn submissions) ─────────────────────────────────
    match /pendingActions/{battleId} {
      allow read:  if isParticipant(battleId);
      allow write: if isParticipant(battleId)
                   && isValidActionPayload(request.resource.data)
                   && !hasAlreadySubmitted(battleId);
    }

    // ── Battle Validation Results (PvP anti-cheat audit trail) ────────────────
    match /validationResults/{battleId} {
      allow read:  if request.auth != null && isParticipant(battleId);
      // Only Cloud Functions may write validation results (server-side only)
      allow write: if false;
    }

    // ── PvP Battle Logs (real-time sync debugging) ─────────────────────────────
    match /pvpBattleLogs/{matchId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null;  // Any authenticated user can log battles
    }

    // ── Matchmaking queue ──────────────────────────────────────────────────────
    match /matchPool/{uid} {
      allow read, write: if request.auth.uid == uid;
    }

    // ── Player progress (reward totals, stage stars) ───────────────────────────
    // Only Cloud Functions may write — prevents client-side reward injection.
    match /playerProgress/{uid} {
      allow read:  if request.auth.uid == uid;
      allow write: if false;
    }

    // ── Helper functions ───────────────────────────────────────────────────────

    function isParticipant(battleId) {
      let b = get(/databases/$(database)/documents/battles/$(battleId)).data;
      return request.auth.uid == b.participants.teamA.playerId
          || request.auth.uid == b.participants.teamB.playerId;
    }

    function isValidActionPayload(data) {
      return data.keys().hasAll(['actions'])
          && data.actions is map;
    }

    function hasAlreadySubmitted(battleId) {
      let pending = get(
        /databases/$(database)/documents/pendingActions/$(battleId)
      ).data;
      return pending != null
          && request.auth.uid in pending.get('actions', {});
    }
  }
}
